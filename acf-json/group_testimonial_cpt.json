{
    "key": "group_testimonial_cpt",
    "title": "Testimonial Details",
    "fields": [
        {
            "key": "field_testimonial_quote",
            "label": "Quote",
            "name": "testimonial_quote",
            "type": "textarea",
            "instructions": "The testimonial quote/review text",
            "required": 1,
            "rows": 6,
            "placeholder": "Enter the testimonial quote here..."
        },
        {
            "key": "field_testimonial_author",
            "label": "Author Name",
            "name": "testimonial_author",
            "type": "text",
            "instructions": "Name of the person giving the testimonial (optional)",
            "required": 0,
            "placeholder": "e.g., John Doe"
        },
        {
            "key": "field_testimonial_role",
            "label": "Author Role/Title",
            "name": "testimonial_role",
            "type": "text",
            "instructions": "Job title or role (optional)",
            "required": 0,
            "placeholder": "e.g., CEO, IT Director"
        },
        {
            "key": "field_testimonial_company",
            "label": "Company Name",
            "name": "testimonial_company",
            "type": "text",
            "instructions": "Company or organization name",
            "required": 1,
            "placeholder": "e.g., Acme Corporation"
        },
        {
            "key": "field_testimonial_company_logo",
            "label": "Company Logo",
            "name": "testimonial_company_logo",
            "type": "image",
            "instructions": "Upload the company logo (recommended: PNG with transparent background)",
            "required": 1,
            "return_format": "url",
            "preview_size": "medium",
            "library": "all"
        },
        {
            "key": "field_testimonial_featured",
            "label": "Featured",
            "name": "testimonial_featured",
            "type": "true_false",
            "instructions": "Mark as featured to show on homepage",
            "default_value": 0,
            "ui": 1,
            "message": "Show this testimonial on the homepage"
        }
    ],
    "location": [
        [
            {
                "param": "post_type",
                "operator": "==",
                "value": "testimonial"
            }
        ]
    ],
    "menu_order": 0,
    "position": "normal",
    "style": "default",
    "label_placement": "top",
    "instruction_placement": "label",
    "active": true
}
